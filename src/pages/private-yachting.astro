---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="el">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Private Yachting | Sota Travel Zakynthos</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
	</head>
	<body class="license-free-body">
		<Header />
		<main class="license-free-page">
			<section class="page-hero" aria-label="Private Yachting">
				<div class="page-hero-overlay"></div>
				<div class="page-hero-content">
					<p class="page-hero-label">LUXURY EXPERIENCE</p>
					<h1 class="page-hero-title">PRIVATE YACHTING</h1>
					<p class="page-hero-subtitle">Experience the ultimate luxury cruise around Zakynthos on a private yacht. Tailored routes, premium service, unforgettable memories.</p>
					<a href="/contact" class="page-hero-cta">CONTACT US TO BOOK</a>
				</div>
			</section>

			<!-- Section 1: Image left, Text right -->
			<section class="py-section" aria-label="Luxury cruises">
				<div class="py-section-inner">
					<div class="py-image-wrap">
						<img src="/images/IMG_0112.jpeg" alt="Luxury yacht cruising the Zakynthos coastline" width="800" height="600" />
					</div>
					<div class="py-text">
						<p class="py-label">EXCLUSIVE CRUISES</p>
						<h2 class="py-title">Discover Zakynthos in Style</h2>
						<p class="py-desc">Sail along the stunning coastline of Zakynthos aboard a private luxury yacht. From the iconic Shipwreck Beach to the crystal-clear waters of the Blue Caves, every cruise is fully customizable. Choose your route, set the pace, and let our professional skipper guide you through the hidden gems of the Ionian Sea.</p>
						<a href="/contact" class="py-cta">BOOK YOUR CRUISE</a>
					</div>
				</div>
			</section>

			<!-- Section 2: Text left, Image right -->
			<section class="py-section py-section--reversed" aria-label="Premium service">
				<div class="py-section-inner">
					<div class="py-image-wrap">
						<img src="/images/IMG_6507.jpeg" alt="Premium onboard service on a private yacht" width="800" height="600" />
					</div>
					<div class="py-text">
						<p class="py-label">PREMIUM SERVICE</p>
						<h2 class="py-title">Unforgettable Moments on Board</h2>
						<p class="py-desc">Whether it's a romantic sunset cruise, a special celebration, or an all-day adventure, our yachts come equipped with everything you need. Enjoy complimentary refreshments, swimming stops at secluded beaches, and the full attention of an experienced crew dedicated to making your experience truly memorable.</p>
						<a href="/contact" class="py-cta">GET IN TOUCH</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />

		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				const header = document.querySelector('.hero-header');
				const heroSection = document.querySelector('.hero');
				if (header) {
					if (!heroSection) {
						header.classList.add('hero-header--scrolled');
					} else {
						const onScroll = () => {
							const heroH = heroSection.getBoundingClientRect().height;
							header.classList.toggle('hero-header--scrolled', window.scrollY >= heroH - 1);
						};
						onScroll();
						window.addEventListener('scroll', onScroll, { passive: true });
					}
				}
			});
		</script>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}
	html {
		scroll-behavior: smooth;
	}
	body {
		margin: 0;
		font-family: 'Inter', system-ui, sans-serif;
		overflow-x: hidden;
	}
	body.license-free-body {
		padding-top: 0;
	}
</style>

<style>
	.license-free-page {
		min-height: 100vh;
	}

	.page-hero {
		position: relative;
		width: 100%;
		min-height: 50vh;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #064250 0%, #0a5a6a 100%);
		overflow: hidden;
		padding-top: 5rem;
	}
	.page-hero-overlay {
		position: absolute;
		inset: 0;
		background: url('/images/IMG_0111.jpeg') center/cover no-repeat;
		opacity: 0.25;
	}
	.page-hero-content {
		position: relative;
		z-index: 1;
		text-align: center;
		padding: 3rem 2rem;
		max-width: 36rem;
	}
	.page-hero-label {
		font-size: 0.75rem;
		letter-spacing: 0.2em;
		color: rgba(255, 255, 255, 0.9);
		margin: 0 0 0.5rem 0;
		text-transform: uppercase;
	}
	.page-hero-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: clamp(2.5rem, 5vw, 3.5rem);
		font-weight: 600;
		color: #fff;
		margin: 0 0 1rem 0;
		line-height: 1.2;
	}
	.page-hero-subtitle {
		font-size: 1.1rem;
		color: rgba(255, 255, 255, 0.9);
		margin: 0 0 1.5rem 0;
		line-height: 1.5;
	}
	.page-hero-cta {
		display: inline-block;
		padding: 0.9rem 2rem;
		background: #fff;
		color: #064250;
		text-decoration: none;
		font-size: 0.85rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		border-radius: 4px;
		transition: opacity 0.2s, transform 0.2s;
	}
	.page-hero-cta:hover {
		opacity: 0.95;
		transform: translateY(-1px);
	}

	/* Alternating image/text sections */
	.py-section {
		width: 100%;
	}
	.py-section-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: 450px;
	}
	.py-image-wrap {
		overflow: hidden;
	}
	.py-image-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		min-height: 400px;
	}
	.py-text {
		background: #f5f0e8;
		padding: 4rem 3rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 1rem;
	}
	.py-section--reversed .py-image-wrap {
		order: 2;
	}
	.py-section--reversed .py-text {
		order: 1;
		background: #fff;
	}
	.py-label {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.2em;
		color: #8b7765;
		margin: 0;
		text-transform: uppercase;
	}
	.py-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: clamp(1.75rem, 3.5vw, 2.5rem);
		font-weight: 700;
		color: #1a1a1a;
		margin: 0;
		line-height: 1.2;
	}
	.py-desc {
		font-size: 1rem;
		line-height: 1.7;
		color: #444;
		margin: 0;
		max-width: 48ch;
	}
	.py-cta {
		display: inline-block;
		align-self: flex-start;
		padding: 0.9rem 2rem;
		background: #1a1a1a;
		color: #fff;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		text-decoration: none;
		transition: background 0.2s;
		margin-top: 0.5rem;
	}
	.py-cta:hover {
		background: #333;
	}

	@media (max-width: 900px) {
		.py-section-inner {
			grid-template-columns: 1fr;
		}
		.py-section--reversed .py-image-wrap {
			order: 0;
		}
		.py-section--reversed .py-text {
			order: 0;
		}
		.py-text {
			padding: 2.5rem 1.5rem;
		}
		.py-image-wrap img {
			min-height: 280px;
			max-height: 350px;
		}
	}
	@media (max-width: 600px) {
		.py-text {
			padding: 2rem 1.25rem;
		}
		.py-image-wrap img {
			min-height: 220px;
			max-height: 300px;
		}
	}
</style>
