---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<html lang="el">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<title>Special Celebrations | Sota Travel Zakynthos</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
	</head>
	<body class="license-free-body">
		<Header />
		<main class="license-free-page">
			<section class="page-hero" aria-label="Special Celebrations">
				<div class="page-hero-overlay"></div>
				<div class="page-hero-content">
					<p class="page-hero-label">UNFORGETTABLE MOMENTS</p>
					<h1 class="page-hero-title">SPECIAL CELEBRATIONS</h1>
					<p class="page-hero-subtitle">Celebrate your most precious moments on a private yacht cruise around the breathtaking island of Zakynthos.</p>
					<a href="/contact" class="page-hero-cta">CONTACT US TO BOOK</a>
				</div>
			</section>

			<!-- Section 1: Full-width text -->
			<section class="py-section" aria-label="Celebrate on the sea">
				<div class="py-section-inner py-section-inner--full">
					<div class="py-text py-text--full">
						<p class="py-label">CELEBRATE IN STYLE</p>
						<h2 class="py-title">Make Every Occasion Extraordinary</h2>
						<p class="py-desc">Whether it's a birthday, a marriage proposal, an anniversary, or any milestone worth celebrating, there's no better setting than the turquoise waters of the Ionian Sea. Our private yacht cruises offer an exclusive and intimate atmosphere to create memories that last a lifetime.</p>
						<a href="/contact" class="py-cta">PLAN YOUR CELEBRATION</a>
					</div>
				</div>
			</section>

			<!-- Section 2: Text left, Image right -->
			<section class="py-section py-section--reversed" aria-label="Tailored celebrations">
				<div class="py-section-inner">
					<div class="py-image-wrap">
						<img src="/images/unnamed.jpg" alt="Sunset celebration cruise in Zakynthos" width="800" height="600" />
					</div>
					<div class="py-text">
						<p class="py-label">TAILORED TO YOUR VISION</p>
						<h2 class="py-title">Your Dream Celebration, Our Expertise</h2>
						<p class="py-desc">Every celebration is unique and we tailor every detail to your wishes. Choose a romantic sunset route, a full-day island adventure, or a secluded beach stop. Our experienced crew takes care of everything so you can focus on enjoying the moment with your loved ones.</p>
						<a href="/contact" class="py-cta">GET IN TOUCH</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />

		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
				const header = document.querySelector('.hero-header');
				const heroSection = document.querySelector('.hero');
				if (header) {
					if (!heroSection) {
						header.classList.add('hero-header--scrolled');
					} else {
						const onScroll = () => {
							const heroH = heroSection.getBoundingClientRect().height;
							header.classList.toggle('hero-header--scrolled', window.scrollY >= heroH - 1);
						};
						onScroll();
						window.addEventListener('scroll', onScroll, { passive: true });
					}
				}
			});
		</script>
	</body>
</html>

<style is:global>
	*,
	*::before,
	*::after {
		box-sizing: border-box;
	}
	html {
		scroll-behavior: smooth;
	}
	body {
		margin: 0;
		font-family: 'Inter', system-ui, sans-serif;
		overflow-x: hidden;
	}
	body.license-free-body {
		padding-top: 0;
	}
</style>

<style>
	.license-free-page {
		min-height: 100vh;
	}

	.page-hero {
		position: relative;
		width: 100%;
		min-height: 50vh;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #064250 0%, #0a5a6a 100%);
		overflow: hidden;
		padding-top: 5rem;
	}
	.page-hero-overlay {
		position: absolute;
		inset: 0;
		background: url('/images/0DF67F7B-8AA7-476C-BCEB-37E088D4925A.png') center/cover no-repeat;
		opacity: 0.25;
	}
	.page-hero-content {
		position: relative;
		z-index: 1;
		text-align: center;
		padding: 3rem 2rem;
		max-width: 36rem;
	}
	.page-hero-label {
		font-size: 0.75rem;
		letter-spacing: 0.2em;
		color: rgba(255, 255, 255, 0.9);
		margin: 0 0 0.5rem 0;
		text-transform: uppercase;
	}
	.page-hero-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: clamp(2.5rem, 5vw, 3.5rem);
		font-weight: 600;
		color: #fff;
		margin: 0 0 1rem 0;
		line-height: 1.2;
	}
	.page-hero-subtitle {
		font-size: 1.1rem;
		color: rgba(255, 255, 255, 0.9);
		margin: 0 0 1.5rem 0;
		line-height: 1.5;
	}
	.page-hero-cta {
		display: inline-block;
		padding: 0.9rem 2rem;
		background: #fff;
		color: #064250;
		text-decoration: none;
		font-size: 0.85rem;
		font-weight: 600;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		border-radius: 4px;
		transition: opacity 0.2s, transform 0.2s;
	}
	.page-hero-cta:hover {
		opacity: 0.95;
		transform: translateY(-1px);
	}

	/* Alternating image/text sections */
	.py-section {
		width: 100%;
	}
	.py-section-inner {
		display: grid;
		grid-template-columns: 1fr 1fr;
		min-height: 450px;
	}
	.py-section-inner--full {
		grid-template-columns: 1fr;
	}
	.py-section-inner--full {
		min-height: auto;
	}
	.py-text--full {
		text-align: center;
		align-items: center;
		max-width: 800px;
		margin: 0 auto;
		padding: 5rem 3rem;
		width: 100%;
		box-sizing: border-box;
	}
	.py-text--full .py-desc {
		max-width: 60ch;
	}
	.py-text--full .py-cta {
		align-self: center;
	}
	.py-image-wrap {
		overflow: hidden;
	}
	.py-image-wrap img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		min-height: 400px;
	}
	.py-text {
		background: #f5f0e8;
		padding: 4rem 3rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
		gap: 1rem;
	}
	.py-section--reversed .py-image-wrap {
		order: 2;
	}
	.py-section--reversed .py-text {
		order: 1;
		background: #fff;
	}
	.py-label {
		font-size: 0.75rem;
		font-weight: 600;
		letter-spacing: 0.2em;
		color: #8b7765;
		margin: 0;
		text-transform: uppercase;
	}
	.py-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: clamp(1.75rem, 3.5vw, 2.5rem);
		font-weight: 700;
		color: #1a1a1a;
		margin: 0;
		line-height: 1.2;
	}
	.py-desc {
		font-size: 1rem;
		line-height: 1.7;
		color: #444;
		margin: 0;
		max-width: 48ch;
	}
	.py-cta {
		display: inline-block;
		align-self: flex-start;
		padding: 0.9rem 2rem;
		background: #1a1a1a;
		color: #fff;
		font-size: 0.8rem;
		font-weight: 600;
		letter-spacing: 0.15em;
		text-transform: uppercase;
		text-decoration: none;
		transition: background 0.2s;
		margin-top: 0.5rem;
	}
	.py-cta:hover {
		background: #333;
	}

	@media (max-width: 900px) {
		.py-section-inner {
			grid-template-columns: 1fr;
		}
		.py-section--reversed .py-image-wrap {
			order: 0;
		}
		.py-section--reversed .py-text {
			order: 0;
		}
		.py-text {
			padding: 2.5rem 1.5rem;
		}
		.py-text--full {
			max-width: 100%;
			padding: 3rem 1.5rem;
		}
		.py-image-wrap img {
			min-height: 280px;
			max-height: 350px;
		}
	}
	@media (max-width: 600px) {
		.py-text {
			padding: 2rem 1.25rem;
		}
		.py-text--full {
			padding: 2.5rem 1.25rem;
		}
		.py-text--full .py-desc {
			max-width: 100%;
		}
		.py-image-wrap img {
			min-height: 220px;
			max-height: 300px;
		}
	}
</style>
