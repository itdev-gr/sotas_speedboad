					var imageWrap = section.querySelector('.selfdrive-image-wrap');
					var text = section.querySelector('.selfdrive-text');
					var isEven = i % 2 === 0;

					if (imageWrap) {
						gsap.from(imageWrap, {
							scrollTrigger: { trigger: section, start: '40% 100%', toggleActions: 'play none none none' },
							x: isEven ? -80 : 80, opacity: 0, duration: 1.35, ease: 'power2.out'
						});
					}
					if (text) {
						gsap.from(text, {
							scrollTrigger: { trigger: section, start: '40% 100%', toggleActions: 'play none none none' },
							x: isEven ? 80 : -80, opacity: 0, duration: 1.35, delay: 0.2, ease: 'power2.out'
						});
					}
				});

				// Footer – fade up
				gsap.from('.site-footer', {
					scrollTrigger: { trigger: '.site-footer', start: 'top 60%', toggleActions: 'play none none none' },
					y: 40, opacity: 0, duration: 1.2, ease: 'power2.out'
				});
			});
		</script>
	</body>
</html>

