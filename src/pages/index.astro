		<script is:inline src="https://cdn.jsdelivr.net/npm/gsap@3.12.7/dist/gsap.min.js"></script>
		<script is:inline>
			document.addEventListener('DOMContentLoaded', () => {
			// GSAP hover animation for services bar icons
			document.querySelectorAll('.services-bar-icon').forEach(function(icon) {
				icon.parentElement.addEventListener('mouseenter', function() {
					gsap.to(icon, { rotation: 15, duration: 0.3, ease: 'power2.out' });
				});
				icon.parentElement.addEventListener('mouseleave', function() {
					gsap.to(icon, { rotation: -15, duration: 0.2, ease: 'power2.inOut',
						onComplete: function() {
							gsap.to(icon, { rotation: 0, duration: 0.3, ease: 'elastic.out(1, 0.5)' });
						}
					});
				});
			});

			const heroImage = document.querySelector('[data-hero-image]');
			const heroVideo = document.querySelector('[data-hero-video]');
			const heroContent = document.querySelector('.hero-content');
			const heroContentSecond = document.querySelector('.hero-content-second');
			const heroContentVideo = document.querySelector('.hero-content-video');
			const prevBtn = document.querySelector('.hero-arrow-prev');
			const nextBtn = document.querySelector('.hero-arrow-next');

			if (heroImage) {
				const slides = [
					{ type: 'image', src: '/images/unnamed.jpg' },
					{ type: 'image', src: '/images/IMG_6566.jpeg' },
					{ type: 'video' }
				];
				let currentIndex = 0;
				let autoTimer = null;

				function goToSlide(index) {
					currentIndex = ((index % slides.length) + slides.length) % slides.length;
					const slide = slides[currentIndex];
					const wrap = heroImage.closest('.hero-image-wrap');

					// Stop video if leaving video slide
					if (heroVideo) {
						heroVideo.pause();
						heroVideo.currentTime = 0;
					}

					if (slide.type === 'image') {
						// Show image, hide video
						heroImage.classList.remove('is-ready');
						heroImage.src = slide.src;
						heroImage.onload = () => heroImage.classList.add('is-ready');
						heroImage.style.display = '';
						if (heroVideo) heroVideo.classList.remove('hero-video--active');
						wrap.classList.toggle('hero-image-wrap--hero2', currentIndex === 1);
						resetAutoPlay();
					} else {
						// Show video, hide image
						heroImage.classList.remove('is-ready');
						heroImage.style.display = 'none';
						wrap.classList.remove('hero-image-wrap--hero2');
						if (heroVideo) {
							heroVideo.classList.add('hero-video--active');
							heroVideo.currentTime = 0;
							heroVideo.play();
						}
						// When video ends, go to first slide
						if (autoTimer) clearTimeout(autoTimer);
					}

					// Toggle text content per slide
					heroContent?.classList.toggle('hero-content--hidden', currentIndex !== 0);
					heroContentSecond?.classList.toggle('hero-content-second--visible', currentIndex === 1);
					heroContentVideo?.classList.toggle('hero-content-video--visible', currentIndex === 2);
				}

				function resetAutoPlay() {
					if (autoTimer) clearTimeout(autoTimer);
					autoTimer = setTimeout(() => goToSlide(currentIndex + 1), 6000);
				}

				// When video ends, loop back to first image
				if (heroVideo) {
					heroVideo.addEventListener('ended', () => goToSlide(0));
				}

				resetAutoPlay();

				if (prevBtn) prevBtn.addEventListener('click', (e) => { e.preventDefault(); goToSlide(currentIndex - 1); });
				if (nextBtn) nextBtn.addEventListener('click', (e) => { e.preventDefault(); goToSlide(currentIndex + 1); });
			}

			const header = document.querySelector('.hero-header');
			const heroSection = document.querySelector('.hero');
			if (header && heroSection) {
				const onScroll = () => {
					const heroH = heroSection.getBoundingClientRect().height;
					header.classList.toggle('hero-header--scrolled', window.scrollY >= heroH - 1);
				};
				onScroll();
				window.addEventListener('scroll', onScroll, { passive: true });
			}
			});
		</script>
