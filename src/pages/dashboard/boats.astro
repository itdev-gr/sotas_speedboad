---
export const prerender = false;
import DashboardLayout from '../../layouts/DashboardLayout.astro';
---
<DashboardLayout title="Boats">
	<h1>Boats</h1>
	<div class="dash-card">
		<div class="boats-toolbar">
			<p class="boats-subtitle">Manage boats shown on the License Free Rent page.</p>
			<button type="button" class="dash-btn" id="add-boat-btn">+ Add Boat</button>
		</div>
		<div style="overflow-x:auto;">
			<table class="dash-table" id="boats-table">
				<thead>
					<tr>
						<th style="width:60px">#</th>
						<th style="width:60px">Image</th>
						<th>Name</th>
						<th>Pax</th>
						<th>4h</th>
						<th>7h</th>
						<th>Skip 4h</th>
						<th>Skip 7h</th>
						<th style="width:120px">Actions</th>
					</tr>
				</thead>
				<tbody id="boats-tbody">
					<tr><td colspan="9">Loading...</td></tr>
				</tbody>
			</table>
		</div>
		<p id="boats-msg" style="margin-top:0.75rem;font-size:0.9rem;color:#666;"></p>
	</div>

	<!-- Side panel -->
	<div id="panel-overlay" class="panel-overlay" hidden></div>
	<div id="side-panel" class="side-panel" hidden>
		<div class="panel-header">
			<h2 id="panel-title">Edit Boat</h2>
			<button type="button" class="panel-close" id="panel-close">&times;</button>
		</div>
		<div class="panel-tabs">
			<button type="button" class="panel-tab active" data-tab="details">Details</button>
			<button type="button" class="panel-tab" data-tab="pricing">Pricing</button>
			<button type="button" class="panel-tab" data-tab="extras">Extras</button>
		</div>
		<form id="boat-form" class="panel-body">
			<input type="hidden" id="f-id" />

			<!-- Details tab -->
			<div class="tab-content active" data-tab="details">
				<div class="pf">
					<label for="f-name">Name (card title)</label>
					<input type="text" id="f-name" required />
				</div>
				<div class="pf">
					<label for="f-modalName">Modal name</label>
					<input type="text" id="f-modalName" placeholder="e.g. Daphne" />
				</div>
				<div class="pf-row">
					<div class="pf">
						<label for="f-lengthMeters">Length (m)</label>
						<input type="text" id="f-lengthMeters" placeholder="5.4" />
					</div>
					<div class="pf">
						<label for="f-maxPax">Max passengers</label>
						<input type="number" id="f-maxPax" min="1" required />
					</div>
				</div>
				<div class="pf">
					<label for="f-description">Description</label>
					<textarea id="f-description" rows="3" placeholder="Short description"></textarea>
				</div>
				<div class="pf">
					<label>Images (1–4)</label>
					<div id="images-grid" class="images-grid"></div>
					<p id="upload-status" style="font-size:0.8rem;color:#888;margin:0.25rem 0 0;"></p>
				</div>
			</div>

			<!-- Pricing tab -->
			<div class="tab-content" data-tab="pricing">
				<div class="pf-row">
					<div class="pf">
						<label for="f-price4h">Price 4h (&euro;)</label>
						<input type="number" id="f-price4h" min="0" step="1" required />
					</div>
					<div class="pf">
						<label for="f-price7h">Price 7h (&euro;)</label>
						<input type="number" id="f-price7h" min="0" step="1" required />
					</div>
				</div>
				<div class="pf-row">
					<div class="pf">
						<label for="f-skipperPrice4h">Skipper 4h (&euro;)</label>
						<input type="number" id="f-skipperPrice4h" min="0" step="1" />
					</div>
					<div class="pf">
						<label for="f-skipperPrice7h">Skipper 7h (&euro;)</label>
						<input type="number" id="f-skipperPrice7h" min="0" step="1" />
					</div>
				</div>
				<div class="pf">
					<label for="f-fuelExcludedText">Fuel note</label>
					<input type="text" id="f-fuelExcludedText" placeholder="Fuel not included" />
				</div>
			</div>

			<!-- Extras tab -->
			<div class="tab-content" data-tab="extras">
				<div class="pf">
					<label for="f-includes">Includes (one per line)</label>
					<textarea id="f-includes" rows="8" placeholder="Meet at the Port&#10;Coolbox with Ice&#10;..."></textarea>
				</div>
				<div class="pf">
					<label for="f-sortOrder">Sort order</label>
					<input type="number" id="f-sortOrder" min="0" />
				</div>
			</div>
		</form>
		<div class="panel-footer">
			<button type="button" class="dash-btn dash-btn--secondary" id="panel-cancel">Cancel</button>
			<button type="button" class="dash-btn" id="panel-save">Save</button>
		</div>
	</div>

	<style>
		/* Toolbar */
		.boats-toolbar {
			display: flex;
			justify-content: space-between;
			align-items: center;
			margin-bottom: 1rem;
			flex-wrap: wrap;
			gap: 0.5rem;
		}
		.boats-subtitle { margin: 0; font-size: 0.9rem; color: #666; }

		/* Table thumbnail */
		.boat-thumb {
			width: 48px;
			height: 48px;
			object-fit: cover;
			border-radius: 4px;
			background: #f0f4f5;
			display: block;
		}

		/* Sort arrows */
		.sort-btn {
			background: none;
			border: none;
			cursor: pointer;
			padding: 0 2px;
			color: #888;
			font-size: 0.8rem;
			line-height: 1;
		}
		.sort-btn:hover { color: #1d8299; }

		/* Action buttons */
		.act-btn {
			background: none;
			border: none;
			cursor: pointer;
			padding: 0.25rem 0.4rem;
			border-radius: 4px;
			color: #555;
			font-size: 0.85rem;
		}
		.act-btn:hover { background: #f0f0f0; color: #1d8299; }
		.act-btn--danger:hover { color: #c00; }

		/* Panel overlay */
		.panel-overlay {
			position: fixed;
			inset: 0;
			background: rgba(0,0,0,0.35);
			z-index: 99;
		}

		/* Side panel */
		.side-panel {
			position: fixed;
			top: 0;
			right: 0;
			width: 480px;
			max-width: 100vw;
			height: 100vh;
			background: #fff;
			z-index: 100;
			display: flex;
			flex-direction: column;
			box-shadow: -4px 0 24px rgba(0,0,0,0.15);
			transform: translateX(100%);
			transition: transform 0.25s ease;
		}
		.side-panel.open {
			transform: translateX(0);
		}

		.panel-header {
			display: flex;
			justify-content: space-between;
			align-items: center;
			padding: 1rem 1.25rem;
			border-bottom: 1px solid #eee;
			flex-shrink: 0;
		}
		.panel-header h2 { margin: 0; font-size: 1.15rem; }
		.panel-close {
			background: none;
			border: none;
			font-size: 1.5rem;
			color: #888;
			cursor: pointer;
			width: 32px;
			height: 32px;
			display: flex;
			align-items: center;
			justify-content: center;
			border-radius: 4px;
		}
		.panel-close:hover { background: #f0f0f0; }

		/* Tabs */
		.panel-tabs {
			display: flex;
			border-bottom: 1px solid #eee;
			padding: 0 1.25rem;
			flex-shrink: 0;
		}
		.panel-tab {
			background: none;
			border: none;
			padding: 0.6rem 1rem;
			font-size: 0.85rem;
			font-weight: 500;
			color: #888;
			cursor: pointer;
			border-bottom: 2px solid transparent;
			margin-bottom: -1px;
		}
		.panel-tab:hover { color: #333; }
		.panel-tab.active { color: #1d8299; border-bottom-color: #1d8299; }

		/* Panel body */
		.panel-body {
			flex: 1;
			overflow-y: auto;
			padding: 1.25rem;
		}
		.tab-content { display: none; }
		.tab-content.active { display: block; }

		/* Panel form fields */
		.pf { margin-bottom: 0.85rem; }
		.pf label { display: block; font-size: 0.82rem; font-weight: 600; color: #444; margin-bottom: 0.25rem; }
		.pf input, .pf textarea {
			width: 100%;
			padding: 0.5rem 0.6rem;
			border: 1px solid #ddd;
			border-radius: 6px;
			font-size: 0.9rem;
			box-sizing: border-box;
		}
		.pf input:focus, .pf textarea:focus {
			outline: none;
			border-color: #1d8299;
			box-shadow: 0 0 0 2px rgba(29,130,153,0.15);
		}
		.pf textarea { resize: vertical; min-height: 60px; }
		.pf-row { display: flex; gap: 0.75rem; }
		.pf-row > .pf { flex: 1; }

		/* Images grid */
		.images-grid {
			display: grid;
			grid-template-columns: repeat(2, 1fr);
			gap: 0.5rem;
			margin-top: 0.4rem;
		}
		.img-slot {
			position: relative;
			aspect-ratio: 4/3;
			background: #f8f9fa;
			border: 2px dashed #ddd;
			border-radius: 6px;
			display: flex;
			align-items: center;
			justify-content: center;
			overflow: hidden;
			cursor: pointer;
		}
		.img-slot:hover { border-color: #1d8299; }
		.img-slot img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
		}
		.img-slot-empty {
			display: flex;
			flex-direction: column;
			align-items: center;
			gap: 0.2rem;
			color: #aaa;
			font-size: 0.75rem;
		}
		.img-slot-empty svg { opacity: 0.5; }
		.img-slot-remove {
			position: absolute;
			top: 4px;
			right: 4px;
			width: 22px;
			height: 22px;
			background: rgba(0,0,0,0.6);
			color: #fff;
			border: none;
			border-radius: 50%;
			font-size: 0.75rem;
			cursor: pointer;
			display: flex;
			align-items: center;
			justify-content: center;
			line-height: 1;
		}
		.img-slot-remove:hover { background: #c00; }
		.img-slot-badge {
			position: absolute;
			bottom: 4px;
			left: 4px;
			background: rgba(29,130,153,0.85);
			color: #fff;
			font-size: 0.65rem;
			font-weight: 600;
			padding: 1px 5px;
			border-radius: 3px;
		}

		/* Panel footer */
		.panel-footer {
			display: flex;
			justify-content: flex-end;
			gap: 0.75rem;
			padding: 1rem 1.25rem;
			border-top: 1px solid #eee;
			flex-shrink: 0;
		}

		@media (max-width: 600px) {
			.side-panel { width: 100vw; }
		}
	</style>

	<script>
		type Boat = {
			id: string;
			name: string;
			imageUrl: string;
			imageUrls: string[];
			price4h: number;
			price7h: number;
			skipperPrice4h: number;
			skipperPrice7h: number;
			maxPax: number;
			modalName: string;
			includes: string[];
			lengthMeters: string;
			fuelExcludedText: string;
			sortOrder: number;
			description?: string;
		};

		const tbody = document.getElementById('boats-tbody')!;
		const msgEl = document.getElementById('boats-msg')!;
		const panel = document.getElementById('side-panel')!;
		const overlay = document.getElementById('panel-overlay')!;
		const panelTitle = document.getElementById('panel-title')!;
		const form = document.getElementById('boat-form') as HTMLFormElement;
		const imagesGrid = document.getElementById('images-grid')!;
		const uploadStatus = document.getElementById('upload-status')!;

		let boats: Boat[] = [];
		let isCreateMode = false;
		let panelImages: string[] = []; // current images being edited (1-4)

		function esc(s: string) {
			return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
		}

		function showMsg(t: string) { msgEl.textContent = t; }

		// --- Table rendering ---
		function renderTable() {
			if (!boats.length) {
				tbody.innerHTML = '<tr><td colspan="9" style="color:#888;text-align:center;">No boats found.</td></tr>';
				return;
			}
			tbody.innerHTML = boats.map((b, i) => `
				<tr>
					<td>
						<button type="button" class="sort-btn move-up" data-i="${i}" ${i === 0 ? 'disabled' : ''} title="Move up">&#9650;</button>
						<button type="button" class="sort-btn move-down" data-i="${i}" ${i === boats.length - 1 ? 'disabled' : ''} title="Move down">&#9660;</button>
					</td>
					<td><img class="boat-thumb" src="${esc((b.imageUrls && b.imageUrls[0]) || b.imageUrl || '/images/self-drive-boat.png')}" alt="${esc(b.name)}" /></td>
					<td><strong>${esc(b.name)}</strong>${b.modalName ? `<br><small style="color:#888">${esc(b.modalName)}</small>` : ''}</td>
					<td>${b.maxPax}</td>
					<td>&euro;${b.price4h}</td>
					<td>&euro;${b.price7h}</td>
					<td>${b.skipperPrice4h ? '&euro;' + b.skipperPrice4h : '&mdash;'}</td>
					<td>${b.skipperPrice7h ? '&euro;' + b.skipperPrice7h : '&mdash;'}</td>
					<td>
						<button type="button" class="act-btn edit-btn" data-id="${b.id}" title="Edit">&#9998; Edit</button>
						<button type="button" class="act-btn act-btn--danger del-btn" data-id="${b.id}" title="Delete">&#128465;</button>
					</td>
				</tr>
			`).join('');
		}

		// --- Sort / reorder ---
		tbody.addEventListener('click', async (e) => {
			const target = e.target as HTMLElement;
			const btn = target.closest('button');
			if (!btn) return;

			if (btn.classList.contains('move-up') || btn.classList.contains('move-down')) {
				const i = Number(btn.dataset.i);
				const j = btn.classList.contains('move-up') ? i - 1 : i + 1;
				if (j < 0 || j >= boats.length) return;
				// Swap sortOrder values
				const tmpSort = boats[i].sortOrder;
				boats[i].sortOrder = boats[j].sortOrder;
				boats[j].sortOrder = tmpSort;
				// Swap in array
				[boats[i], boats[j]] = [boats[j], boats[i]];
				renderTable();
				// Persist both
				await Promise.all([
					fetch('/api/boats', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, credentials: 'include', body: JSON.stringify({ id: boats[i].id, sortOrder: boats[i].sortOrder }) }),
					fetch('/api/boats', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, credentials: 'include', body: JSON.stringify({ id: boats[j].id, sortOrder: boats[j].sortOrder }) }),
				]);
			}

			if (btn.classList.contains('edit-btn')) {
				const boat = boats.find(b => b.id === btn.dataset.id);
				if (boat) openPanel(boat, false);
			}

			if (btn.classList.contains('del-btn')) {
				const id = btn.dataset.id!;
				const boat = boats.find(b => b.id === id);
				if (!confirm(`Delete "${boat?.name || id}"? This cannot be undone.`)) return;
				const res = await fetch('/api/boats', { method: 'DELETE', headers: { 'Content-Type': 'application/json' }, credentials: 'include', body: JSON.stringify({ id }) });
				if (res.ok) { showMsg('Deleted.'); loadBoats(); }
				else { const d = await res.json().catch(() => ({})); showMsg(d.error || 'Delete failed.'); }
			}
		});

		// --- Panel ---
		function openPanel(boat: Boat, create: boolean) {
			isCreateMode = create;
			panelTitle.textContent = create ? 'Add Boat' : 'Edit Boat';
			(document.getElementById('f-id') as HTMLInputElement).value = boat.id;
			(document.getElementById('f-name') as HTMLInputElement).value = boat.name;
			(document.getElementById('f-modalName') as HTMLInputElement).value = boat.modalName || '';
			(document.getElementById('f-lengthMeters') as HTMLInputElement).value = boat.lengthMeters || '';
			(document.getElementById('f-maxPax') as HTMLInputElement).value = String(boat.maxPax || '');
			(document.getElementById('f-description') as HTMLTextAreaElement).value = boat.description || '';
			// Build images array: imageUrls if available, fall back to imageUrl
			const urls = (boat.imageUrls && boat.imageUrls.length) ? [...boat.imageUrls] : (boat.imageUrl ? [boat.imageUrl] : []);
			panelImages = urls.filter(Boolean).slice(0, 4);
			renderImagesGrid();
			(document.getElementById('f-price4h') as HTMLInputElement).value = String(boat.price4h || '');
			(document.getElementById('f-price7h') as HTMLInputElement).value = String(boat.price7h || '');
			(document.getElementById('f-skipperPrice4h') as HTMLInputElement).value = String(boat.skipperPrice4h || '');
			(document.getElementById('f-skipperPrice7h') as HTMLInputElement).value = String(boat.skipperPrice7h || '');
			(document.getElementById('f-fuelExcludedText') as HTMLInputElement).value = boat.fuelExcludedText || 'Fuel not included';
			(document.getElementById('f-includes') as HTMLTextAreaElement).value = (boat.includes || []).join('\n');
			(document.getElementById('f-sortOrder') as HTMLInputElement).value = String(boat.sortOrder || '');
			uploadStatus.textContent = '';
			// Reset to Details tab
			switchTab('details');
			panel.hidden = false;
			overlay.hidden = false;
			requestAnimationFrame(() => panel.classList.add('open'));
			document.body.style.overflow = 'hidden';
		}

		function closePanel() {
			panel.classList.remove('open');
			setTimeout(() => {
				panel.hidden = true;
				overlay.hidden = true;
			}, 250);
			document.body.style.overflow = '';
		}

		document.getElementById('panel-close')!.addEventListener('click', closePanel);
		document.getElementById('panel-cancel')!.addEventListener('click', closePanel);
		overlay.addEventListener('click', closePanel);
		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && !panel.hidden) closePanel();
		});

		// --- Tabs ---
		function switchTab(name: string) {
			document.querySelectorAll('.panel-tab').forEach(t => t.classList.toggle('active', t.getAttribute('data-tab') === name));
			document.querySelectorAll('.tab-content').forEach(c => c.classList.toggle('active', c.getAttribute('data-tab') === name));
		}
		document.querySelector('.panel-tabs')!.addEventListener('click', (e) => {
			const tab = (e.target as HTMLElement).closest('.panel-tab');
			if (tab) switchTab(tab.getAttribute('data-tab')!);
		});

		// --- Multi-image grid ---
		function renderImagesGrid() {
			const MAX = 4;
			let html = '';
			for (let i = 0; i < MAX; i++) {
				const url = panelImages[i] || '';
				if (url) {
					html += `<div class="img-slot" data-i="${i}">
						<img src="${esc(url)}" alt="Image ${i + 1}" />
						<button type="button" class="img-slot-remove" data-i="${i}" title="Remove">&times;</button>
						${i === 0 ? '<span class="img-slot-badge">Main</span>' : ''}
					</div>`;
				} else if (i <= panelImages.length) {
					// Show one empty slot after the last filled one (or slot 0 if none)
					html += `<div class="img-slot img-slot-add" data-i="${i}">
						<span class="img-slot-empty">
							<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4"/><polyline points="17 8 12 3 7 8"/><line x1="12" y1="3" x2="12" y2="15"/></svg>
							Add image
						</span>
						<input type="file" accept="image/*" hidden />
					</div>`;
					break; // only one empty add-slot at a time
				}
			}
			imagesGrid.innerHTML = html;
		}

		imagesGrid.addEventListener('click', (e) => {
			const target = e.target as HTMLElement;
			// Remove button
			const removeBtn = target.closest('.img-slot-remove') as HTMLElement;
			if (removeBtn) {
				e.stopPropagation();
				const i = Number(removeBtn.dataset.i);
				panelImages.splice(i, 1);
				renderImagesGrid();
				return;
			}
			// Click on add slot -> trigger file input
			const addSlot = target.closest('.img-slot-add') as HTMLElement;
			if (addSlot) {
				const fileInput = addSlot.querySelector('input[type="file"]') as HTMLInputElement;
				fileInput?.click();
			}
		});

		imagesGrid.addEventListener('change', async (e: Event) => {
			const input = e.target as HTMLInputElement;
			if (input.type !== 'file') return;
			const file = input.files?.[0];
			if (!file) return;
			const boatId = (document.getElementById('f-id') as HTMLInputElement).value.trim();
			if (!boatId) { uploadStatus.textContent = 'Save the boat first, then upload.'; input.value = ''; return; }
			const slot = input.closest('.img-slot-add') as HTMLElement;
			const idx = Number(slot?.dataset.i ?? panelImages.length);
			uploadStatus.textContent = `Uploading image ${idx + 1}...`;
			try {
				const { getFirebaseStorage } = await import('../../lib/firebase');
				const { ref, uploadBytes, getDownloadURL } = await import('firebase/storage');
				const storage = getFirebaseStorage();
				if (!storage) { uploadStatus.textContent = 'Storage not configured.'; input.value = ''; return; }
				const path = `boats/${boatId}/img_${idx}.jpg`;
				const storageRef = ref(storage, path);
				await uploadBytes(storageRef, file);
				const url = await getDownloadURL(storageRef);
				panelImages[idx] = url;
				renderImagesGrid();
				uploadStatus.textContent = 'Uploaded. Click Save to keep.';
			} catch (err) { uploadStatus.textContent = 'Upload failed.'; console.error(err); }
			input.value = '';
		});

		// --- Save ---
		document.getElementById('panel-save')!.addEventListener('click', async () => {
			if (!form.reportValidity()) return;
			const id = (document.getElementById('f-id') as HTMLInputElement).value.trim();
			const includesText = (document.getElementById('f-includes') as HTMLTextAreaElement).value.trim();
			const includes = includesText ? includesText.split('\n').map(s => s.trim()).filter(Boolean) : [];
			const payload = {
				id,
				name: (document.getElementById('f-name') as HTMLInputElement).value.trim(),
				imageUrl: panelImages[0] || '',
				imageUrls: [...panelImages],
				price4h: Number((document.getElementById('f-price4h') as HTMLInputElement).value) || 0,
				price7h: Number((document.getElementById('f-price7h') as HTMLInputElement).value) || 0,
				skipperPrice4h: Number((document.getElementById('f-skipperPrice4h') as HTMLInputElement).value) || 0,
				skipperPrice7h: Number((document.getElementById('f-skipperPrice7h') as HTMLInputElement).value) || 0,
				maxPax: Number((document.getElementById('f-maxPax') as HTMLInputElement).value) || 0,
				modalName: (document.getElementById('f-modalName') as HTMLInputElement).value.trim(),
				lengthMeters: (document.getElementById('f-lengthMeters') as HTMLInputElement).value.trim(),
				fuelExcludedText: (document.getElementById('f-fuelExcludedText') as HTMLInputElement).value.trim() || 'Fuel not included',
				includes,
				description: (document.getElementById('f-description') as HTMLTextAreaElement).value.trim(),
				sortOrder: Number((document.getElementById('f-sortOrder') as HTMLInputElement).value) || 0,
			};
			showMsg('');
			const res = await fetch('/api/boats', { method: 'PUT', headers: { 'Content-Type': 'application/json' }, credentials: 'include', body: JSON.stringify(payload) });
			if (res.ok) { showMsg('Saved.'); closePanel(); loadBoats(); }
			else { const d = await res.json().catch(() => ({})); showMsg(d.error || 'Save failed.'); }
		});

		// --- Add boat ---
		document.getElementById('add-boat-btn')!.addEventListener('click', () => {
			const newId = 'boat_' + Date.now();
			const nextOrder = boats.length ? Math.max(...boats.map(b => b.sortOrder)) + 1 : 1;
			openPanel({
				id: newId, name: '', imageUrl: '', imageUrls: [], price4h: 0, price7h: 0,
				skipperPrice4h: 0, skipperPrice7h: 0, maxPax: 0, modalName: '', includes: [],
				lengthMeters: '', fuelExcludedText: 'Fuel not included', sortOrder: nextOrder, description: '',
			}, true);
		});

		// --- Load ---
		async function loadBoats() {
			const res = await fetch('/api/boats', { credentials: 'include' });
			if (!res.ok) { tbody.innerHTML = '<tr><td colspan="9" style="color:#c00;">Failed to load boats.</td></tr>'; return; }
			boats = await res.json();
			renderTable();
		}

		loadBoats();
	</script>
</DashboardLayout>
