---
import { getCollection, render } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Reading time (~200 wpm on the raw body)
const wordCount = (post.body ?? '').split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.round(wordCount / 200));

// Table of contents — H2s only for clarity
const toc = (headings ?? []).filter((h) => h.depth === 2);

// FAQ extraction: lines that look like "**Question?** Answer"
const body = post.body ?? '';
const faqMatches = Array.from(
	body.matchAll(/\*\*([^*]+?\?)\*\*\s*([^\n]+(?:\n(?!\n)[^\n]+)*)/g),
);
const faqs = faqMatches.map((m) => ({ q: m[1].trim(), a: m[2].trim() }));

// Related posts
const all = (await getCollection('blog')).sort(
	(a, b) => (a.data.order ?? 999) - (b.data.order ?? 999),
);
const related = all.filter((p) => p.id !== post.id).slice(0, 3);

const dateFmt = new Intl.DateTimeFormat('en-GB', {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});

const SITE = 'https://rentaboatzakynthos.com';
const canonical = `${SITE}/blog/${post.id}`;
const heroImage = post.data.image;
const heroAlt = post.data.imageAlt ?? post.data.title;
const published = post.data.pubDate.toISOString();
const updated = (post.data.updatedDate ?? post.data.pubDate).toISOString();

// JSON-LD: Article + Breadcrumbs + (optional) FAQ
const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'BlogPosting',
	headline: post.data.title,
	alternativeHeadline: post.data.metaTitle ?? post.data.title,
	description: post.data.metaDescription,
	image: [`${SITE}${heroImage}`],
	datePublished: published,
	dateModified: updated,
	wordCount,
	timeRequired: `PT${readingMinutes}M`,
	inLanguage: 'en',
	articleSection: post.data.category ?? 'Boat Rental Guides',
	keywords: [
		'Zakynthos boat rental',
		'boat rental Zakynthos',
		'Navagio',
		'Blue Caves',
		'Greece boat hire',
	].join(', '),
	author: {
		'@type': 'Organization',
		name: 'Sota Travel Zakynthos',
		url: SITE,
	},
	publisher: {
		'@type': 'Organization',
		name: 'Sota Travel Zakynthos',
		logo: {
			'@type': 'ImageObject',
			url: `${SITE}/images/sota-travel-logo.svg`,
		},
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': canonical,
	},
	speakable: {
		'@type': 'SpeakableSpecification',
		cssSelector: ['.post-hero-title', '.post-prose p:first-of-type'],
	},
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: SITE },
		{ '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE}/blog` },
		{ '@type': 'ListItem', position: 3, name: post.data.title, item: canonical },
	],
};

const faqSchema =
	faqs.length > 0
		? {
				'@context': 'https://schema.org',
				'@type': 'FAQPage',
				mainEntity: faqs.map((f) => ({
					'@type': 'Question',
					name: f.q,
					acceptedAnswer: { '@type': 'Answer', text: f.a },
				})),
			}
		: null;
---

<html lang="en">
	<head>
		<SEOHead
			title={post.data.metaTitle ?? post.data.title}
			description={post.data.metaDescription}
			canonical={canonical}
			ogImage={`${SITE}${heroImage}`}
			ogType="article"
		/>
		<meta property="article:published_time" content={published} />
		<meta property="article:modified_time" content={updated} />
		<meta property="article:author" content="Sota Travel Zakynthos" />
		<meta property="article:section" content={post.data.category ?? 'Boat Rental Guides'} />
		<meta property="article:tag" content="Zakynthos boat rental" />
		<meta property="article:tag" content="Navagio" />
		<meta property="article:tag" content="Blue Caves" />
		<link rel="preload" as="image" href={heroImage} fetchpriority="high" />
		<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
		{faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
	</head>
	<body class="post-body">
		<div class="reading-progress" id="reading-progress" aria-hidden="true"></div>
		<Header />
		<main class="post-page">
			<article class="post-article-wrap" itemscope itemtype="https://schema.org/BlogPosting">
				<meta itemprop="datePublished" content={published} />
				<meta itemprop="dateModified" content={updated} />
				<meta itemprop="wordCount" content={String(wordCount)} />

				<section class="post-hero" aria-label={post.data.title}>
					<div class="post-hero-bg" style={`background-image: url(${heroImage})`} role="img" aria-label={heroAlt}></div>
					<div class="post-hero-overlay"></div>
					<div class="post-hero-inner">
						<nav class="breadcrumbs" aria-label="Breadcrumb">
							<ol>
								<li><a href="/" itemprop="item"><span itemprop="name">Home</span></a></li>
								<li aria-hidden="true">›</li>
								<li><a href="/blog"><span>Blog</span></a></li>
								<li aria-hidden="true">›</li>
								<li aria-current="page"><span>{post.data.title}</span></li>
							</ol>
						</nav>
						<h1 class="post-hero-title" itemprop="headline">{post.data.title}</h1>
						<p class="post-hero-meta">
							<time datetime={published} itemprop="datePublished">{dateFmt.format(post.data.pubDate)}</time>
							<span class="meta-dot">·</span>
							<span>{readingMinutes} min read</span>
							<span class="meta-dot">·</span>
							<span itemprop="author" itemscope itemtype="https://schema.org/Organization">
								<span itemprop="name">Sota Travel Team</span>
							</span>
						</p>
					</div>
				</section>

				<div class="post-layout">
					{toc.length > 1 && (
						<aside class="post-toc" aria-label="On this page">
							<p class="post-toc-label">On this page</p>
							<ol class="post-toc-list">
								{toc.map((h) => (
									<li><a href={`#${h.slug}`}>{h.text}</a></li>
								))}
							</ol>
						</aside>
					)}

					<div class="post-content">
						<div class="post-prose" itemprop="articleBody">
							<Content />
						</div>

						<div class="post-share" aria-label="Share this article">
							<span class="post-share-label">Share</span>
							<a class="share-btn" rel="noopener" target="_blank" href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(canonical)}`} aria-label="Share on Facebook">Facebook</a>
							<a class="share-btn" rel="noopener" target="_blank" href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(canonical)}&text=${encodeURIComponent(post.data.title)}`} aria-label="Share on X">X</a>
							<a class="share-btn" rel="noopener" target="_blank" href={`https://www.linkedin.com/sharing/share-offsite/?url=${encodeURIComponent(canonical)}`} aria-label="Share on LinkedIn">LinkedIn</a>
							<a class="share-btn" rel="noopener" target="_blank" href={`https://api.whatsapp.com/send?text=${encodeURIComponent(post.data.title + ' ' + canonical)}`} aria-label="Share on WhatsApp">WhatsApp</a>
						</div>

						<aside class="post-cta">
							<h3>Want help booking a route from this article?</h3>
							<p>Tell us your group size and dates and we'll match you to the right boat and rental option.</p>
							<div class="post-cta-buttons">
								<a class="post-cta-btn post-cta-btn--primary" href="/contact">Contact Us</a>
								<a class="post-cta-btn post-cta-btn--secondary" href="/license-free-rent">License-Free Rentals</a>
								<a class="post-cta-btn post-cta-btn--secondary" href="/rent-with-skipper">Rent with Skipper</a>
							</div>
						</aside>

						<div class="post-author">
							<div class="post-author-avatar" aria-hidden="true">ST</div>
							<div class="post-author-text">
								<p class="post-author-name">Sota Travel Team</p>
								<p class="post-author-bio">Zakynthos-based boat rental specialists. Years of experience matching travellers to the right boats, skippers and routes around the island.</p>
								<p class="post-author-links">
									<a href="/contact">Contact the team</a>
									<span class="meta-dot">·</span>
									<a href="tel:+306987931327">Call 0030 698 793 1327</a>
								</p>
							</div>
						</div>
					</div>
				</div>
			</article>

			{related.length > 0 && (
				<section class="related-section" aria-label="Related articles">
					<div class="related-inner">
						<h2 class="related-title">Keep reading</h2>
						<div class="related-grid">
							{related.map((r) => (
								<a class="related-card" href={`/blog/${r.id}`}>
									<div class="related-card-image">
										<img src={r.data.image} alt={r.data.imageAlt ?? r.data.title} width="400" height="260" loading="lazy" decoding="async" />
									</div>
									<div class="related-card-body">
										<h3>{r.data.title}</h3>
										<p>{r.data.excerpt ?? r.data.metaDescription}</p>
									</div>
								</a>
							))}
						</div>
					</div>
				</section>
			)}
		</main>
		<Footer />
		<script>
			(() => {
				const bar = document.getElementById('reading-progress');
				const article = document.querySelector('.post-article-wrap');
				if (!bar || !article) return;
				const update = () => {
					const rect = (article as HTMLElement).getBoundingClientRect();
					const total = rect.height - window.innerHeight;
					const scrolled = Math.min(Math.max(-rect.top, 0), Math.max(total, 1));
					const pct = total > 0 ? (scrolled / total) * 100 : 0;
					(bar as HTMLElement).style.width = pct + '%';
				};
				update();
				window.addEventListener('scroll', update, { passive: true });
				window.addEventListener('resize', update);
			})();
		</script>
	</body>
</html>

<style is:global>
	*, *::before, *::after { box-sizing: border-box; }
	html { scroll-behavior: smooth; }
	body { margin: 0; font-family: 'Inter', system-ui, sans-serif; overflow-x: hidden; }
	body.post-body { padding-top: 0; background: #fdfcf9; }
</style>

<style>
	.reading-progress {
		position: fixed;
		top: 0;
		left: 0;
		height: 3px;
		width: 0%;
		background: linear-gradient(90deg, #0a5a6a, #2a9aae);
		z-index: 9999;
		transition: width 0.08s linear;
	}

	.post-page { min-height: 100vh; }

	.post-hero {
		position: relative;
		width: 100%;
		min-height: 56vh;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		background: #064250;
		overflow: hidden;
		padding-top: 5rem;
	}
	.post-hero-bg {
		position: absolute;
		inset: 0;
		background-size: cover;
		background-position: center;
		transform: scale(1.02);
	}
	.post-hero-overlay {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(180deg, rgba(6, 66, 80, 0.45) 0%, rgba(6, 66, 80, 0.88) 100%);
	}
	.post-hero-inner {
		position: relative;
		z-index: 2;
		color: #fff;
		padding: 2.5rem 1.5rem 3rem;
		max-width: 1080px;
		width: 100%;
	}

	.breadcrumbs ol {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
		list-style: none;
		padding: 0;
		margin: 0 0 1.5rem;
		font-size: 0.88rem;
		opacity: 0.92;
	}
	.breadcrumbs a {
		color: #fff;
		text-decoration: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.4);
		padding-bottom: 1px;
	}
	.breadcrumbs a:hover { border-bottom-color: #fff; }
	.breadcrumbs [aria-current="page"] {
		opacity: 0.85;
		max-width: 56ch;
		overflow: hidden;
		text-overflow: ellipsis;
		white-space: nowrap;
	}

	.post-hero-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: clamp(2rem, 4.6vw, 3.4rem);
		line-height: 1.13;
		margin: 0 0 0.85rem;
		font-weight: 600;
		max-width: 22ch;
	}
	.post-hero-meta {
		font-size: 0.92rem;
		letter-spacing: 0.04em;
		opacity: 0.9;
		margin: 0;
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
	}
	.meta-dot { opacity: 0.55; }

	.post-layout {
		display: grid;
		grid-template-columns: minmax(0, 240px) minmax(0, 1fr);
		gap: 3rem;
		max-width: 1080px;
		margin: 0 auto;
		padding: 3.5rem 1.5rem 1rem;
		align-items: start;
	}

	.post-toc {
		position: sticky;
		top: 6rem;
		padding: 1.25rem 1.25rem 1.5rem;
		background: #fff;
		border: 1px solid #ece8db;
		border-radius: 12px;
		box-shadow: 0 4px 14px rgba(6, 66, 80, 0.06);
		font-size: 0.92rem;
	}
	.post-toc-label {
		font-size: 0.72rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: #0a5a6a;
		margin: 0 0 0.85rem;
		font-weight: 600;
	}
	.post-toc-list {
		list-style: none;
		padding: 0;
		margin: 0;
		display: flex;
		flex-direction: column;
		gap: 0.55rem;
		counter-reset: toc;
	}
	.post-toc-list li {
		counter-increment: toc;
		display: flex;
		gap: 0.55rem;
		line-height: 1.4;
	}
	.post-toc-list li::before {
		content: counter(toc, decimal-leading-zero);
		font-feature-settings: 'tnum';
		color: #b9b0a0;
		font-size: 0.78rem;
		padding-top: 0.1rem;
	}
	.post-toc-list a {
		color: #2a3a40;
		text-decoration: none;
		border-bottom: 1px solid transparent;
	}
	.post-toc-list a:hover {
		color: #064250;
		border-bottom-color: #0a5a6a;
	}

	.post-content { min-width: 0; }

	.post-prose {
		font-size: 1.085rem;
		line-height: 1.78;
		color: #2a3a40;
		max-width: 70ch;
	}
	.post-prose :global(p) { margin: 0 0 1.2rem; }
	.post-prose :global(p:first-of-type)::first-letter {
		font-family: 'Cormorant Garamond', serif;
		float: left;
		font-size: 3.6rem;
		line-height: 0.95;
		padding: 0.35rem 0.6rem 0 0;
		color: #064250;
		font-weight: 600;
	}
	.post-prose :global(h2) {
		font-family: 'Cormorant Garamond', serif;
		font-size: clamp(1.55rem, 3vw, 2.1rem);
		color: #064250;
		margin: 2.75rem 0 1rem;
		line-height: 1.22;
		font-weight: 600;
		scroll-margin-top: 5.5rem;
		position: relative;
		padding-left: 1.1rem;
	}
	.post-prose :global(h2)::before {
		content: '';
		position: absolute;
		left: 0;
		top: 0.45rem;
		bottom: 0.45rem;
		width: 4px;
		background: linear-gradient(180deg, #0a5a6a, #2a9aae);
		border-radius: 3px;
	}
	.post-prose :global(h3) {
		font-family: 'Inter', sans-serif;
		font-size: 1.2rem;
		color: #064250;
		margin: 1.85rem 0 0.55rem;
		font-weight: 600;
		letter-spacing: -0.005em;
		scroll-margin-top: 5.5rem;
	}
	.post-prose :global(ul),
	.post-prose :global(ol) {
		margin: 0 0 1.4rem 0;
		padding: 0 0 0 1.2rem;
	}
	.post-prose :global(li) {
		margin: 0 0 0.55rem;
		padding-left: 0.25rem;
	}
	.post-prose :global(li::marker) { color: #2a9aae; }
	.post-prose :global(strong) { color: #064250; }
	.post-prose :global(a) {
		color: #0a5a6a;
		text-decoration: underline;
		text-underline-offset: 3px;
	}
	.post-prose :global(blockquote) {
		border-left: 3px solid #0a5a6a;
		padding: 0.25rem 0 0.25rem 1.1rem;
		margin: 1.6rem 0;
		color: #4a5a60;
		font-style: italic;
	}

	.post-share {
		display: flex;
		flex-wrap: wrap;
		align-items: center;
		gap: 0.6rem;
		margin: 3rem 0 0;
		padding: 1.2rem 1.4rem;
		background: #fff;
		border: 1px solid #ece8db;
		border-radius: 12px;
	}
	.post-share-label {
		font-size: 0.78rem;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		color: #0a5a6a;
		font-weight: 600;
		margin-right: 0.4rem;
	}
	.share-btn {
		display: inline-block;
		padding: 0.45rem 0.85rem;
		border-radius: 999px;
		background: #f3f1ea;
		color: #064250;
		font-size: 0.85rem;
		font-weight: 500;
		text-decoration: none;
		border: 1px solid transparent;
		transition: background 0.2s, border-color 0.2s;
	}
	.share-btn:hover {
		background: #fff;
		border-color: #d6d2c6;
	}

	.post-cta {
		margin: 2rem 0 1rem;
		padding: 2rem;
		background: #f3f1ea;
		border-radius: 14px;
		border: 1px solid #e9e6dd;
	}
	.post-cta h3 {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.55rem;
		margin: 0 0 0.5rem;
		color: #064250;
		font-weight: 600;
	}
	.post-cta p {
		margin: 0 0 1.25rem;
		color: #4a5a60;
		line-height: 1.55;
	}
	.post-cta-buttons {
		display: flex;
		flex-wrap: wrap;
		gap: 0.7rem;
	}
	.post-cta-btn {
		display: inline-block;
		padding: 0.75rem 1.25rem;
		text-decoration: none;
		border-radius: 6px;
		font-weight: 500;
		font-size: 0.95rem;
	}
	.post-cta-btn--primary { background: #064250; color: #fff; }
	.post-cta-btn--primary:hover { background: #0a5a6a; }
	.post-cta-btn--secondary {
		background: #fff;
		color: #064250;
		border: 1px solid #d6d2c6;
	}
	.post-cta-btn--secondary:hover { background: #ece9df; }

	.post-author {
		margin-top: 3rem;
		display: flex;
		gap: 1.1rem;
		padding: 1.5rem;
		background: #fff;
		border: 1px solid #ece8db;
		border-radius: 14px;
	}
	.post-author-avatar {
		flex-shrink: 0;
		width: 56px;
		height: 56px;
		border-radius: 999px;
		background: linear-gradient(135deg, #064250, #0a5a6a);
		color: #fff;
		display: flex;
		align-items: center;
		justify-content: center;
		font-family: 'Cormorant Garamond', serif;
		font-weight: 600;
		font-size: 1.15rem;
		letter-spacing: 0.04em;
	}
	.post-author-name {
		margin: 0 0 0.25rem;
		font-weight: 600;
		color: #064250;
	}
	.post-author-bio {
		margin: 0 0 0.5rem;
		font-size: 0.95rem;
		color: #4a5a60;
		line-height: 1.55;
	}
	.post-author-links {
		margin: 0;
		font-size: 0.9rem;
		color: #4a5a60;
		display: flex;
		gap: 0.5rem;
		flex-wrap: wrap;
		align-items: center;
	}
	.post-author-links a {
		color: #0a5a6a;
		text-decoration: none;
		border-bottom: 1px solid currentColor;
	}

	.related-section {
		background: #064250;
		color: #fff;
		padding: 4rem 1.5rem;
		margin-top: 4rem;
	}
	.related-inner {
		max-width: 1200px;
		margin: 0 auto;
	}
	.related-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: clamp(1.85rem, 3.6vw, 2.4rem);
		margin: 0 0 2rem;
		font-weight: 600;
	}
	.related-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
		gap: 1.5rem;
	}
	.related-card {
		display: flex;
		flex-direction: column;
		background: rgba(255, 255, 255, 0.06);
		border: 1px solid rgba(255, 255, 255, 0.1);
		border-radius: 12px;
		overflow: hidden;
		text-decoration: none;
		color: #fff;
		transition: background 0.2s, transform 0.2s;
	}
	.related-card:hover {
		background: rgba(255, 255, 255, 0.1);
		transform: translateY(-2px);
	}
	.related-card-image { aspect-ratio: 16 / 10; }
	.related-card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}
