---
import { getCollection } from 'astro:content';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';

const posts = (await getCollection('blog')).sort((a, b) => {
	const ao = a.data.order ?? 999;
	const bo = b.data.order ?? 999;
	if (ao !== bo) return ao - bo;
	return b.data.pubDate.getTime() - a.data.pubDate.getTime();
});

const featured = posts[0];
const rest = posts.slice(1);

const dateFmt = new Intl.DateTimeFormat('en-GB', { year: 'numeric', month: 'long', day: 'numeric' });

const SITE = 'https://rentaboatzakynthos.com';

const itemListSchema = {
	'@context': 'https://schema.org',
	'@type': 'ItemList',
	itemListElement: posts.map((p, i) => ({
		'@type': 'ListItem',
		position: i + 1,
		url: `${SITE}/blog/${p.id}`,
		name: p.data.title,
	})),
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{ '@type': 'ListItem', position: 1, name: 'Home', item: SITE },
		{ '@type': 'ListItem', position: 2, name: 'Blog', item: `${SITE}/blog` },
	],
};

const blogSchema = {
	'@context': 'https://schema.org',
	'@type': 'Blog',
	name: 'Sota Travel — Zakynthos Boat Rental Blog',
	description: 'Boat rental guides, route breakdowns and travel tips for Zakynthos.',
	url: `${SITE}/blog`,
	publisher: {
		'@type': 'Organization',
		name: 'Sota Travel Zakynthos',
		logo: { '@type': 'ImageObject', url: `${SITE}/images/sota-travel-logo.svg` },
	},
	blogPost: posts.map((p) => ({
		'@type': 'BlogPosting',
		headline: p.data.title,
		url: `${SITE}/blog/${p.id}`,
		datePublished: p.data.pubDate.toISOString(),
		image: `${SITE}${p.data.image}`,
	})),
};
---

<html lang="en">
	<head>
		<SEOHead
			title="Zakynthos Boat Rental Blog | Routes, Tips & Guides | Sota Travel"
			description="Honest, in-depth guides to renting a boat in Zakynthos. Navagio Shipwreck, Blue Caves, sunset tours, no-license rentals, private cruises and more — from the team that runs the boats."
			canonical={`${SITE}/blog`}
			ogImage={`${SITE}${featured.data.image}`}
		/>
		<link rel="preload" as="image" href={featured.data.image} fetchpriority="high" />
		<script type="application/ld+json" set:html={JSON.stringify(blogSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	</head>
	<body class="blog-body">
		<Header />
		<main class="blog-page">
			<section class="page-hero" aria-label="Blog">
				<div class="page-hero-overlay"></div>
				<div class="page-hero-content">
					<nav class="breadcrumbs breadcrumbs--hero" aria-label="Breadcrumb">
						<ol>
							<li><a href="/">Home</a></li>
							<li aria-hidden="true">›</li>
							<li aria-current="page">Blog</li>
						</ol>
					</nav>
					<p class="page-hero-label">SOTA TRAVEL JOURNAL</p>
					<h1 class="page-hero-title">The Zakynthos Boat Rental Blog</h1>
					<p class="page-hero-subtitle">In-depth guides to the routes, durations and rental options that actually work on Zakynthos — written by the team who runs the boats.</p>
				</div>
			</section>

			<section class="featured-section" aria-label="Featured article">
				<a class="featured-card" href={`/blog/${featured.id}`}>
					<div class="featured-image">
						<img src={featured.data.image} alt={featured.data.imageAlt ?? featured.data.title} width="1200" height="800" fetchpriority="high" decoding="async" />
						<span class="featured-tag">Featured</span>
					</div>
					<div class="featured-body">
						<p class="featured-date">
							<time datetime={featured.data.pubDate.toISOString()}>{dateFmt.format(featured.data.pubDate)}</time>
							<span class="meta-dot">·</span>
							<span>{featured.data.category ?? 'Boat Rental Guides'}</span>
						</p>
						<h2 class="featured-title">{featured.data.title}</h2>
						<p class="featured-excerpt">{featured.data.excerpt ?? featured.data.metaDescription}</p>
						<span class="featured-cta">Read the full guide →</span>
					</div>
				</a>
			</section>

			<section class="blog-grid-section" aria-label="All posts">
				<div class="blog-grid-header">
					<h2 class="blog-grid-heading">All articles</h2>
					<p class="blog-grid-count">{posts.length} guides</p>
				</div>
				<div class="blog-grid">
					{rest.map((post) => (
						<a class="blog-card" href={`/blog/${post.id}`}>
							<div class="blog-card-image">
								<img src={post.data.image} alt={post.data.imageAlt ?? post.data.title} width="600" height="400" loading="lazy" decoding="async" />
							</div>
							<div class="blog-card-body">
								<p class="blog-card-date">
									<time datetime={post.data.pubDate.toISOString()}>{dateFmt.format(post.data.pubDate)}</time>
								</p>
								<h3 class="blog-card-title">{post.data.title}</h3>
								<p class="blog-card-excerpt">{post.data.excerpt ?? post.data.metaDescription}</p>
								<span class="blog-card-cta">Read article →</span>
							</div>
						</a>
					))}
				</div>
			</section>

			<section class="blog-cta-section" aria-label="Contact">
				<div class="blog-cta-inner">
					<h2 class="blog-cta-title">Ready to plan your day on the water?</h2>
					<p class="blog-cta-desc">Tell us your group size, the dates, and how long you want out there. We'll help you pick the right route, boat and rental option.</p>
					<div class="blog-cta-buttons">
						<a href="/contact" class="blog-cta-btn blog-cta-btn--primary">Contact Us</a>
						<a href="tel:+306987931327" class="blog-cta-btn blog-cta-btn--secondary">Call: 0030 698 793 1327</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style is:global>
	*, *::before, *::after { box-sizing: border-box; }
	html { scroll-behavior: smooth; }
	body { margin: 0; font-family: 'Inter', system-ui, sans-serif; overflow-x: hidden; }
	body.blog-body { padding-top: 0; }
</style>

<style>
	.blog-page { min-height: 100vh; background: #fdfcf9; }

	.page-hero {
		position: relative;
		width: 100%;
		min-height: 52vh;
		display: flex;
		align-items: center;
		justify-content: center;
		background: linear-gradient(135deg, #064250 0%, #0a5a6a 100%);
		overflow: hidden;
		padding-top: 5rem;
	}
	.page-hero-overlay {
		position: absolute;
		inset: 0;
		background: url('/images/IMG_6416.jpeg') center/cover no-repeat;
		opacity: 0.32;
	}
	.page-hero-content {
		position: relative;
		z-index: 2;
		text-align: center;
		color: #fff;
		padding: 3.5rem 1.5rem;
		max-width: 820px;
	}
	.breadcrumbs--hero ol {
		justify-content: center;
		margin-bottom: 1rem;
	}
	.breadcrumbs ol {
		display: flex;
		flex-wrap: wrap;
		gap: 0.5rem;
		align-items: center;
		list-style: none;
		padding: 0;
		margin: 0;
		font-size: 0.85rem;
		opacity: 0.92;
	}
	.breadcrumbs a {
		color: #fff;
		text-decoration: none;
		border-bottom: 1px solid rgba(255, 255, 255, 0.4);
		padding-bottom: 1px;
	}
	.breadcrumbs a:hover { border-bottom-color: #fff; }
	.breadcrumbs [aria-current="page"] { opacity: 0.85; }
	.page-hero-label {
		font-size: 0.85rem;
		font-weight: 500;
		letter-spacing: 0.18em;
		opacity: 0.85;
		margin: 0 0 1rem;
	}
	.page-hero-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: clamp(2.25rem, 5vw, 3.85rem);
		font-weight: 600;
		line-height: 1.1;
		margin: 0 0 1rem;
	}
	.page-hero-subtitle {
		font-size: 1.05rem;
		line-height: 1.6;
		opacity: 0.9;
		margin: 0 auto;
		max-width: 640px;
	}

	.featured-section {
		max-width: 1200px;
		margin: -5rem auto 0;
		padding: 0 1.5rem;
		position: relative;
		z-index: 3;
	}
	.featured-card {
		display: grid;
		grid-template-columns: 1.15fr 1fr;
		background: #fff;
		border-radius: 18px;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		box-shadow: 0 24px 50px rgba(6, 66, 80, 0.18);
		transition: transform 0.25s ease, box-shadow 0.25s ease;
	}
	.featured-card:hover {
		transform: translateY(-3px);
		box-shadow: 0 28px 56px rgba(6, 66, 80, 0.22);
	}
	.featured-image {
		position: relative;
		min-height: 360px;
		overflow: hidden;
	}
	.featured-image img {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: transform 0.5s ease;
	}
	.featured-card:hover .featured-image img { transform: scale(1.04); }
	.featured-tag {
		position: absolute;
		top: 1rem;
		left: 1rem;
		background: #fff;
		color: #064250;
		font-size: 0.72rem;
		font-weight: 600;
		letter-spacing: 0.16em;
		text-transform: uppercase;
		padding: 0.4rem 0.8rem;
		border-radius: 999px;
	}
	.featured-body {
		padding: 2.5rem 2.25rem;
		display: flex;
		flex-direction: column;
		justify-content: center;
	}
	.featured-date {
		font-size: 0.82rem;
		letter-spacing: 0.1em;
		text-transform: uppercase;
		color: #0a5a6a;
		margin: 0 0 0.85rem;
		font-weight: 500;
		display: flex;
		gap: 0.5rem;
		align-items: center;
	}
	.meta-dot { opacity: 0.5; }
	.featured-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: clamp(1.7rem, 2.6vw, 2.2rem);
		line-height: 1.18;
		margin: 0 0 0.85rem;
		color: #064250;
		font-weight: 600;
	}
	.featured-excerpt {
		font-size: 1rem;
		line-height: 1.6;
		color: #4a5a60;
		margin: 0 0 1.4rem;
	}
	.featured-cta {
		color: #0a5a6a;
		font-weight: 600;
		font-size: 0.97rem;
	}

	.blog-grid-section {
		padding: 5rem 1.5rem 4rem;
		max-width: 1200px;
		margin: 0 auto;
	}
	.blog-grid-header {
		display: flex;
		align-items: baseline;
		justify-content: space-between;
		margin-bottom: 2rem;
		flex-wrap: wrap;
		gap: 1rem;
	}
	.blog-grid-heading {
		font-family: 'Cormorant Garamond', serif;
		font-size: clamp(1.7rem, 3vw, 2.3rem);
		margin: 0;
		color: #064250;
		font-weight: 600;
	}
	.blog-grid-count {
		margin: 0;
		font-size: 0.85rem;
		letter-spacing: 0.14em;
		text-transform: uppercase;
		color: #0a5a6a;
		font-weight: 500;
	}
	.blog-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
		gap: 2rem;
	}
	.blog-card {
		display: flex;
		flex-direction: column;
		background: #fff;
		border-radius: 14px;
		overflow: hidden;
		text-decoration: none;
		color: inherit;
		border: 1px solid #ece8db;
		box-shadow: 0 4px 18px rgba(6, 66, 80, 0.06);
		transition: transform 0.25s ease, box-shadow 0.25s ease, border-color 0.25s ease;
	}
	.blog-card:hover {
		transform: translateY(-4px);
		box-shadow: 0 12px 28px rgba(6, 66, 80, 0.14);
		border-color: #d6d2c6;
	}
	.blog-card-image {
		aspect-ratio: 16 / 10;
		overflow: hidden;
	}
	.blog-card-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
		transition: transform 0.5s ease;
	}
	.blog-card:hover .blog-card-image img { transform: scale(1.04); }
	.blog-card-body {
		padding: 1.5rem 1.5rem 1.75rem;
		display: flex;
		flex-direction: column;
		flex: 1;
	}
	.blog-card-date {
		font-size: 0.78rem;
		letter-spacing: 0.12em;
		text-transform: uppercase;
		color: #0a5a6a;
		margin: 0 0 0.7rem;
		font-weight: 500;
	}
	.blog-card-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: 1.5rem;
		line-height: 1.25;
		margin: 0 0 0.75rem;
		color: #064250;
		font-weight: 600;
	}
	.blog-card-excerpt {
		font-size: 0.97rem;
		line-height: 1.55;
		color: #4a5a60;
		margin: 0 0 1.25rem;
		flex: 1;
	}
	.blog-card-cta {
		color: #0a5a6a;
		font-weight: 500;
		font-size: 0.95rem;
		align-self: flex-start;
	}

	.blog-cta-section {
		background: linear-gradient(135deg, #064250 0%, #0a5a6a 100%);
		color: #fff;
		padding: 4rem 1.5rem;
		text-align: center;
	}
	.blog-cta-inner { max-width: 720px; margin: 0 auto; }
	.blog-cta-title {
		font-family: 'Cormorant Garamond', serif;
		font-size: clamp(1.85rem, 4vw, 2.6rem);
		margin: 0 0 0.75rem;
		font-weight: 600;
	}
	.blog-cta-desc {
		font-size: 1.05rem;
		line-height: 1.6;
		opacity: 0.9;
		margin: 0 0 1.75rem;
	}
	.blog-cta-buttons {
		display: flex;
		gap: 0.85rem;
		justify-content: center;
		flex-wrap: wrap;
	}
	.blog-cta-btn {
		display: inline-block;
		padding: 0.85rem 1.6rem;
		text-decoration: none;
		border-radius: 6px;
		font-weight: 500;
		letter-spacing: 0.02em;
		transition: background 0.2s, border-color 0.2s, color 0.2s;
	}
	.blog-cta-btn--primary { background: #fff; color: #064250; }
	.blog-cta-btn--primary:hover { background: #f0eee8; }
	.blog-cta-btn--secondary {
		background: transparent;
		color: #fff;
		border: 1px solid rgba(255, 255, 255, 0.6);
	}
	.blog-cta-btn--secondary:hover {
		background: rgba(255, 255, 255, 0.12);
		border-color: #fff;
	}

	@media (max-width: 860px) {
		.featured-section { margin-top: -3rem; }
		.featured-card { grid-template-columns: 1fr; }
		.featured-image { min-height: 240px; }
		.featured-body { padding: 1.75rem 1.5rem 2rem; }
	}
</style>
