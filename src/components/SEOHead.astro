---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogImage = 'https://rentaboatzakynthos.com/images/unnamed.jpg',
  ogType = 'website',
  noindex = false,
} = Astro.props;

const canonicalURL = canonical || new URL(Astro.url.pathname, Astro.site).href;
---

<meta charset="utf-8" />

<!-- Google tag (gtag.js) -->
<script async src="https://www.googletagmanager.com/gtag/js?id=G-XX59D06X4W"></script>
<script is:inline>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', 'G-XX59D06X4W');
  gtag('config', 'AW-18123954099');
</script>

<!-- Event snippet for Προβολή σελίδας conversion page -->
<script is:inline>
  function gtag_report_conversion(url) {
    var callback = function () {
      if (typeof(url) != 'undefined') {
        window.location = url;
      }
    };
    gtag('event', 'conversion', {
        'send_to': 'AW-18123954099/h8FuCOeMwMUcELOvlsJD',
        'event_callback': callback
    });
    return false;
  }

  // Fire the Google Ads conversion when users click contact / booking actions.
  document.addEventListener('click', function (e) {
    var link = e.target && e.target.closest ? e.target.closest('a') : null;
    if (!link) return;
    var href = link.getAttribute('href') || '';
    var isConversion =
      href.indexOf('tel:') === 0 ||
      href.indexOf('wa.me') !== -1 ||
      href.indexOf('/contact') === 0 ||
      href === '/license-free-rent' ||
      href === '/rent-with-skipper' ||
      href === '/private-yachting' ||
      (link.className && String(link.className).indexOf('floating-contact__item') !== -1);
    if (!isConversion) return;
    gtag('event', 'conversion', {
      'send_to': 'AW-18123954099/h8FuCOeMwMUcELOvlsJD'
    });
  }, true);
</script>

<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="canonical" href={canonicalURL} />
{noindex && <meta name="robots" content="noindex, nofollow" />}

<!-- Open Graph -->
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalURL} />
<meta property="og:image" content={ogImage} />
<meta property="og:type" content={ogType} />
<meta property="og:site_name" content="Sota Travel Zakynthos" />
<meta property="og:locale" content="en_US" />

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImage} />

<!-- Geo tags for local SEO -->
<meta name="geo.region" content="GR-21" />
<meta name="geo.placename" content="Zakynthos" />
<meta name="geo.position" content="37.7870;20.8979" />
<meta name="ICBM" content="37.7870, 20.8979" />

<!-- Fonts -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet" />
