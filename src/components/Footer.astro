<footer class="site-footer" aria-label="Footer">
	<div class="footer-main">
		<div class="footer-col footer-about">
			<a href="/" class="footer-logo" aria-label="Sota Travel Zakynthos">
				<img class="footer-logo-img" src="/images/sota-travel-logo.svg" alt="Sota Travel Zakynthos" />
			</a>
		</div>
		<div class="footer-col footer-links-col">
			<h3 class="footer-title">Links</h3>
			<ul class="footer-links">
				<li><a href="/license-free-rent">Self Drive</a></li>
				<li><a href="/rent-with-skipper">Skipper Drive</a></li>
				<li><a href="/private-yachting">Private Yachting</a></li>
				<li><a href="/special-celebrations">Special Celebrations</a></li>
				<li><a href="/recommended-routes">Recommended Routes</a></li>
				<li><a href="/faq">FAQ</a></li>
				<li><a href="/contact">Contact</a></li>
			</ul>
		</div>
		<div class="footer-col footer-useful">
			<h3 class="footer-title">Useful</h3>
			<ul class="footer-links">
				<li><a href="/#terms">Terms of Use</a></li>
				<li><a href="/#privacy">Privacy Policy</a></li>
				<li><a href="/#cookies">Cookie Policy</a></li>
			</ul>
		</div>
		<div class="footer-col footer-find">
			<h3 class="footer-title">Find us</h3>
			<p class="footer-company">Sota Travel Zakynthos</p>
			<p class="footer-address">Zakynthos, Ionian</p>
			<p class="footer-contact">
				<a href="tel:+306970621594">+30 697 062 1594</a>
			</p>
			<p class="footer-contact">
				<a href="mailto:info@boatrentalzakynthos.com">info@boatrentalzakynthos.com</a>
			</p>
		</div>
	</div>
	<div class="footer-bottom">
		<p class="footer-copyright">© Copyright 2026, Sota Travel Zakynthos – Designed and Developed by <a href="https://www.itdev.gr/" target="_blank" rel="noopener noreferrer">IT DEV</a></p>
	</div>
</footer>
<script is:inline>
(function() {
	var script = document.createElement('script');
	script.src = 'https://cbl.link/b/foZ1bvN.js';
	script.async = true;
	document.head.appendChild(script);
})();
</script>

<style>
	.site-footer {
		background: #064250;
		color: #fff;
		width: 100%;
	}
	.footer-main {
		display: grid;
		grid-template-columns: 1.2fr 1fr 1fr 1.2fr;
		gap: 2rem 3rem;
		max-width: 1200px;
		margin: 0 auto;
		padding: 3rem 2rem 4rem;
	}
	.footer-col {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1rem;
	}
	.footer-logo {
		display: flex;
		margin-bottom: 0.25rem;
		text-decoration: none;
		color: inherit;
	}
	.footer-logo-img {
		height: 100px;
		width: auto;
		display: block;
	}
	.footer-title {
		font-size: 1rem;
		font-weight: 700;
		margin: 0;
		color: #fff;
		letter-spacing: 0.02em;
	}
	.footer-links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.footer-links a {
		color: #fff;
		text-decoration: none;
		font-size: 0.9rem;
		opacity: 0.9;
	}
	.footer-links a:hover {
		opacity: 1;
		text-decoration: underline;
	}
	.footer-company,
	.footer-address,
	.footer-contact {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.5;
		color: #fff;
		opacity: 0.95;
	}
	.footer-contact a {
		color: #fff;
		text-decoration: none;
	}
	.footer-contact a:hover {
		text-decoration: underline;
	}
	.footer-bottom {
		border-top: 1px solid rgba(255, 255, 255, 0.15);
		padding: 1rem 2rem;
	}
	.footer-copyright {
		margin: 0;
		font-size: 0.8rem;
		color: rgba(255, 255, 255, 0.75);
		text-align: center;
		max-width: 1200px;
		margin-left: auto;
		margin-right: auto;
	}
	.footer-copyright a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
	}
	.footer-copyright a:hover {
		text-decoration: underline;
	}
	@media (max-width: 900px) {
		.footer-main {
			grid-template-columns: 1fr 1fr;
			padding: 2rem 1.5rem 3rem;
		}
	}
	@media (max-width: 600px) {
		.footer-main {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.footer-copyright {
			font-size: 0.75rem;
		}
	}
</style>
