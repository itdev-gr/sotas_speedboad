---
import FloatingContact from './FloatingContact.astro';
---
<footer class="site-footer" aria-label="Footer">
	<div class="footer-main">
		<div class="footer-col footer-about">
			<a href="/" class="footer-logo" aria-label="Sota Travel Zakynthos">
				<svg class="footer-logo-img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 520" fill="none" aria-hidden="true">
					<g fill="#D4A017">
						<rect x="135" y="68" width="130" height="14" rx="2"/>
						<polygon points="140,68 155,22 170,58 170,68"/>
						<polygon points="182,68 200,8 218,68"/>
						<polygon points="230,68 245,22 260,68"/>
						<circle cx="155" cy="20" r="6"/>
						<circle cx="200" cy="6" r="7"/>
						<circle cx="245" cy="20" r="6"/>
					</g>
					<path d="M108,88 L108,250 Q108,310 200,360 Q292,310 292,250 L292,88 Z" fill="none" stroke="#D4A017" stroke-width="10"/>
					<path d="M122,100 L122,246 Q122,300 200,344 Q278,300 278,246 L278,100 Z" fill="none" stroke="#D4A017" stroke-width="3"/>
					<text x="200" y="215" text-anchor="middle" font-family="'Cormorant Garamond','Times New Roman',serif" font-weight="800" font-size="80" fill="#D4A017" letter-spacing="6">STZ</text>
					<g stroke="#D4A017" fill="none" stroke-width="3.5" stroke-linecap="round">
						<path d="M155,260 Q167,250 179,260 Q191,270 203,260 Q215,250 227,260 Q239,270 248,260"/>
						<path d="M160,275 Q172,265 184,275 Q196,285 208,275 Q220,265 232,275 Q240,282 245,275"/>
						<path d="M168,289 Q178,281 188,289 Q198,297 208,289 Q218,281 228,289"/>
					</g>
					<text x="200" y="415" text-anchor="middle" font-family="'Cormorant Garamond','Times New Roman',serif" font-weight="900" font-size="48" fill="#D4A017" letter-spacing="5">SOTA TRAVEL</text>
					<text x="200" y="458" text-anchor="middle" font-family="'Cormorant Garamond','Times New Roman',serif" font-weight="700" font-size="32" fill="#D4A017" letter-spacing="4">ZAKYNTHOS</text>
					<text x="200" y="495" text-anchor="middle" font-family="'Cormorant Garamond','Times New Roman',serif" font-weight="700" font-size="24" fill="#D4A017" letter-spacing="3">- VIP CRUISE -</text>
				</svg>
			</a>
			<h3 class="footer-title">Links</h3>
			<ul class="footer-links">
				<li><a href="/license-free-rent">Self Drive</a></li>
				<li><a href="/rent-with-skipper">Skipper Drive</a></li>
				<li><a href="/private-yachting">Private Yachting</a></li>
				<li><a href="/special-celebrations">Special Celebrations</a></li>
				<li><a href="/recommended-routes">Recommended Routes</a></li>
				<li><a href="/faq">FAQ</a></li>
				<li><a href="/contact">Contact</a></li>
			</ul>
		</div>
		<div class="footer-col footer-useful">
			<h3 class="footer-title">Useful</h3>
			<ul class="footer-links">
				<li><a href="/#terms">Terms of Use</a></li>
				<li><a href="/#privacy">Privacy Policy</a></li>
				<li><a href="/#cookies">Cookie Policy</a></li>
			</ul>
		</div>
		<div class="footer-col footer-find">
			<h3 class="footer-title">Find us</h3>
			<p class="footer-company">Sota Travel Zakynthos</p>
			<p class="footer-address">Zakynthos, Ionian</p>
			<p class="footer-contact">
				<a href="tel:+306970621594">+30 697 062 1594</a>
			</p>
			<p class="footer-contact">
				<a href="mailto:info@boatrentalzakynthos.com">info@boatrentalzakynthos.com</a>
			</p>
		</div>
	</div>
	<div class="footer-bottom">
		<p class="footer-copyright">© Copyright 2026, Sota Travel Zakynthos – Designed and Developed by <a href="https://www.itdev.gr/" target="_blank" rel="noopener noreferrer">IT DEV</a></p>
	</div>
</footer>
<FloatingContact />

<style>
	.site-footer {
		background: #064250;
		color: #fff;
		width: 100%;
	}
	.footer-main {
		display: grid;
		grid-template-columns: 1.2fr 1fr 1.2fr;
		gap: 2rem 3rem;
		max-width: 1200px;
		margin: 0 auto;
		padding: 3rem 2rem 4rem;
	}
	.footer-col {
		display: flex;
		flex-direction: column;
		align-items: flex-start;
		gap: 1rem;
	}
	.footer-logo {
		display: flex;
		margin-bottom: 0.25rem;
		text-decoration: none;
		color: inherit;
	}
	.footer-logo-img {
		height: 100px;
		width: auto;
		display: block;
	}
	.footer-title {
		font-size: 1rem;
		font-weight: 700;
		margin: 0;
		color: #fff;
		letter-spacing: 0.02em;
	}
	.footer-links {
		list-style: none;
		margin: 0;
		padding: 0;
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.footer-links a {
		color: #fff;
		text-decoration: none;
		font-size: 0.9rem;
		opacity: 0.9;
	}
	.footer-links a:hover {
		opacity: 1;
		text-decoration: underline;
	}
	.footer-company,
	.footer-address,
	.footer-contact {
		margin: 0;
		font-size: 0.9rem;
		line-height: 1.5;
		color: #fff;
		opacity: 0.95;
	}
	.footer-contact a {
		color: #fff;
		text-decoration: none;
	}
	.footer-contact a:hover {
		text-decoration: underline;
	}
	.footer-bottom {
		border-top: 1px solid rgba(255, 255, 255, 0.15);
		padding: 1rem 2rem;
	}
	.footer-copyright {
		margin: 0;
		font-size: 0.8rem;
		color: rgba(255, 255, 255, 0.75);
		text-align: center;
		max-width: 1200px;
		margin-left: auto;
		margin-right: auto;
	}
	.footer-copyright a {
		color: rgba(255, 255, 255, 0.85);
		text-decoration: none;
	}
	.footer-copyright a:hover {
		text-decoration: underline;
	}
	@media (max-width: 900px) {
		.footer-main {
			grid-template-columns: 1fr 1fr;
			padding: 2rem 1.5rem 3rem;
		}
	}
	@media (max-width: 600px) {
		.footer-main {
			grid-template-columns: 1fr;
			gap: 2rem;
		}
		.footer-copyright {
			font-size: 0.75rem;
		}
	}
</style>
