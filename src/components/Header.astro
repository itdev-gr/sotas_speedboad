---
<header class="hero-header" id="main-header">
	<a href="/" class="nav-logo" aria-label="Sota Travel Zakynthos">
		<svg class="nav-logo-img" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 400 520" fill="none" aria-hidden="true">
